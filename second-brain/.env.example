# ========================================
# Second Brain — Environment Variables
# ========================================
# Copy this file to .env and fill in values.
# All variables are OPTIONAL — defaults work out of the box.

# --- Server ---
# SB_HOST=0.0.0.0
# SB_PORT=8000

# --- Knowledge Vault ---
# SB_KNOWLEDGE_DIR=./knowledge

# --- Ollama (LLM for AI Chat) ---
# SB_OLLAMA_URL=http://localhost:11434
# SB_LLM_MODEL=qwen2.5:7b-instruct-q4_K_M

# --- Telegram Bot (Phase 2, not yet implemented) ---
# SB_TELEGRAM_TOKEN=your-bot-token-here

# --- Embedding Model Cache (project-local) ---
# Set this to keep HuggingFace model downloads inside the project:
# HF_HOME=./docker-data/huggingface
# SENTENCE_TRANSFORMERS_HOME=./docker-data/sentence-transformers
